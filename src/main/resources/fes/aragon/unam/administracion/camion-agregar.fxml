<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="540.0" prefWidth="380.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fes.aragon.unam.administracion.controller.AgregarCamionController">

    <children>

        <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="45.0" prefWidth="380.0" style="-fx-background-color: #313A46;">
            <children>
                <Label fx:id="lblTitulo" alignment="CENTER" layoutX="0.0" layoutY="8.0" prefHeight="30.0" prefWidth="380.0" text="Camión" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <Label layoutX="25.0" layoutY="65.0" text="ID:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <TextField fx:id="txtId" disable="true" layoutX="140.0" layoutY="61.0" prefHeight="26.0" prefWidth="210.0" promptText="Automático" />

        <Label layoutX="25.0" layoutY="100.0" text="Matricula:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <TextField fx:id="txtMatricula" layoutX="140.0" layoutY="96.0" prefHeight="26.0" prefWidth="210.0" promptText="6 dígitos, ej: 15001" />

        <Label layoutX="27.0" layoutY="175.0" text="Trabajador:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>

        <Button fx:id="btnGuardar" layoutX="47.0" layoutY="481.0" onAction="#guardar" prefHeight="32.0" prefWidth="110.0" style="-fx-background-color: #005995; -fx-font-weight: bold;" text="Guardar" textFill="WHITE">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>

        <Button fx:id="btnCancelar" layoutX="222.0" layoutY="481.0" onAction="#cancelar" prefHeight="32.0" prefWidth="110.0" style="-fx-background-color: #FF1436; -fx-font-weight: bold;" text="Cancelar" textFill="WHITE">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
      <ComboBox fx:id="cmbTrabajador" layoutX="142.0" layoutY="171.0" prefHeight="26.0" prefWidth="210.0" promptText="Selecciona" />
      <Label layoutX="173.0" layoutY="205.0" text="Zonas:">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Label>
      <ListView fx:id="lwDisp" layoutX="29.0" layoutY="231.0" prefHeight="200.0" prefWidth="150.0" />
      <ListView fx:id="lwSelect" layoutX="204.0" layoutY="231.0" prefHeight="200.0" prefWidth="150.0" />
      <Label layoutX="32.0" layoutY="458.0" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11;" text=" Doble clic en una fila para moverla" />
      <Label layoutX="72.0" layoutY="431.0" text="Disponibles">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Label>
      <Label layoutX="242.0" layoutY="431.0" text="Seleccionado">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Label>
      <Label layoutX="25.0" layoutY="136.0" text="Fecha:">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Label>
      <TextField fx:id="txtFecha" disable="true" layoutX="140.0" layoutY="132.0" prefHeight="26.0" prefWidth="210.0" promptText="Automático" />

    </children>
</AnchorPane>
