<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="400.0" prefWidth="600.0"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="fes.aragon.unam.administracion.controller.ZonasController">

    <children>

        <AnchorPane layoutX="-2.0" layoutY="0.0" prefHeight="55.0" prefWidth="602.0"
                    style="-fx-background-color: #313A46;">
            <children>
                <Label alignment="CENTER" layoutX="2.0" layoutY="9.0"
                       prefHeight="36.0" prefWidth="600.0"
                       text="Zonas de Distribución - Perú"
                       textFill="WHITE">
                    <font><Font name="System Bold" size="25.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <TableView fx:id="tablaZonas"
                   layoutX="30.0" layoutY="80.0"
                   prefHeight="300.0" prefWidth="540.0">
            <columns>
                <TableColumn fx:id="colId"           text="ID"            prefWidth="60.0"  />
                <TableColumn fx:id="colCp"           text="Código Postal" prefWidth="150.0" />
                <TableColumn fx:id="colDepartamento" text="Departamento"  prefWidth="327.0" />
            </columns>
        </TableView>

    </children>
</AnchorPane>