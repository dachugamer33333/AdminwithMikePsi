<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="420.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fes.aragon.unam.administracion.controller.ZonasController">

    <children>

        <!-- BARRA SUPERIOR -->
        <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="55.0" prefWidth="750.0"
                    style="-fx-background-color: #313A46;">
            <children>
                <Label alignment="CENTER" layoutX="0.0" layoutY="9.0"
                       prefHeight="36.0" prefWidth="750.0"
                       text="Zonas de Distribución - Perú" textFill="WHITE">
                    <font><Font name="System Bold" size="25.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <!-- BOTÓN AGREGAR -->
        <Button layoutX="560.0" layoutY="80.0"
                prefHeight="30.0" prefWidth="110.0"
                text="+  Agregar"
                textFill="WHITE"
                style="-fx-background-color: #28a745; -fx-font-weight: bold; -fx-cursor: hand;"
                onAction="#abrirAgregar">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>

        <!-- TABLA — anchos ajustados para que quepan todas las columnas -->
        <TableView fx:id="tablaZonas"
                   layoutX="75.0" layoutY="122.0"
                   prefHeight="325.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="colId"           text="ID"           prefWidth="25.0"  />
                <TableColumn fx:id="colDepartamento" text="Departamento" prefWidth="105.0" />
                <TableColumn fx:id="colCp"           text="Cód. Postal"  prefWidth="78.0"  />
                <TableColumn fx:id="colReferencia"   text="Referencia"   prefWidth="180.0" />
                <TableColumn fx:id="colEstado"       text="Estado"       prefWidth="80.0"  />
                <TableColumn fx:id="colAcciones"     text="Acciones"     prefWidth="100.0" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
