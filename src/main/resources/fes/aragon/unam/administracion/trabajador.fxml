      <TextField fx:id="txtApellido" layoutX="415.0" layoutY="216.0" prefHeight="26.0" prefWidth="220.0" />
      <Button fx:id="btnEstado" layoutX="539.0" layoutY="99.0" mnemonicParsing="false" onAction="#cambiarEstado" prefHeight="25.0" prefWidth="75.0" text="Inactivo" textFill="#e11e1e">
