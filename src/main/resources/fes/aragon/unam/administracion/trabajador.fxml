      <Button fx:id="btnLimpiar" layoutX="537.0" layoutY="410.0" mnemonicParsing="false" onAction="#limpiar" prefHeight="30.0" prefWidth="95.0" style="-fx-background-color: #51AAC6;" text="Limpiar" textFill="WHITE">
