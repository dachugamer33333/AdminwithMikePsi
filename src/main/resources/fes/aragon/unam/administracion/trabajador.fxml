      </Label>
      <AnchorPane layoutX="461.0" layoutY="251.0" prefHeight="120.0" prefWidth="122.0">
         <children>
            <ImageView fx:id="imgTrabajador" fitHeight="111.0" fitWidth="125.0" layoutX="-3.0" layoutY="11.0" pickOnBounds="true" preserveRatio="true" />
            <Button fx:id="btnSubirFoto" layoutX="1.0" layoutY="120.0" mnemonicParsing="false" onAction="#subirFoto" prefHeight="26.0" prefWidth="119.0" text="Subir Foto" />
         </children>
      </AnchorPane>
      <TextField fx:id="txtIdEmpleado" layoutX="413.0" layoutY="99.0" prefHeight="25.0" prefWidth="90.0" promptText="ID" />
      <Label layoutX="413.0" layoutY="74.0" text="ID">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label layoutX="413.0" layoutY="134.0" text="Nombre">
         <font>
            <Font name="System Bold" size="15.0" />
