            <Font name="System Bold" size="16.0" />
         </font>
      </Button>
      <Button fx:id="btnAnadir" layoutX="415.0" layoutY="410.0" mnemonicParsing="false" onAction="#anadir" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: #005995;" text="Agregar" textFill="WHITE">
