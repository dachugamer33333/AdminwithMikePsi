<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="290.0" prefWidth="380.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fes.aragon.unam.administracion.controller.ZonasAgregarController">

    <children>

        <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="45.0" prefWidth="380.0"
                    style="-fx-background-color: #313A46;">
            <children>
                <Label fx:id="lblTitulo" alignment="CENTER"
                       layoutX="0.0" layoutY="8.0"
                       prefHeight="30.0" prefWidth="380.0"
                       text="Zona" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
            </children>
        </AnchorPane>

        <Label layoutX="25.0" layoutY="65.0" text="ID:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <TextField fx:id="txtId" layoutX="140.0" layoutY="61.0"
                   prefHeight="26.0" prefWidth="210.0"
                   disable="true" promptText="Automático" />

        <Label layoutX="25.0" layoutY="103.0" text="Departamento:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <ComboBox fx:id="cmbDepartamento" layoutX="140.0" layoutY="99.0"
                  prefHeight="26.0" prefWidth="210.0"
                  promptText="Selecciona..." />

        <Label layoutX="25.0" layoutY="141.0" text="Cód. Postal:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <TextField fx:id="txtCp" layoutX="140.0" layoutY="137.0"
                   prefHeight="26.0" prefWidth="210.0"
                   promptText="5 dígitos, ej: 15001" />

        <Label layoutX="25.0" layoutY="179.0" text="Referencia:">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <TextField fx:id="txtReferencia" layoutX="140.0" layoutY="175.0"
                   prefHeight="26.0" prefWidth="210.0"
                   promptText="Nota opcional..." />

        <Button layoutX="55.0" layoutY="230.0"
                prefHeight="32.0" prefWidth="110.0"
                text="Guardar" textFill="WHITE"
                style="-fx-background-color: #005995; -fx-font-weight: bold;"
                onAction="#guardar">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>

        <Button layoutX="210.0" layoutY="230.0"
                prefHeight="32.0" prefWidth="110.0"
                text="Cancelar" textFill="WHITE"
                style="-fx-background-color: #FF1436; -fx-font-weight: bold;"
                onAction="#cancelar">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>

    </children>
</AnchorPane>
